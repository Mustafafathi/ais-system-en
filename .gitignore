# Logs, caches, exports, and backups
*.log
*.tmp
*.temp
*.cache
*.bak
*.backup
*.zip
*.7z
*.rar
*.sql.bak

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Dependency folders, if introduced later
vendor/
node_modules/
